  "components": {
    "schemas": {
      "BloodStockDTO": {
        "properties": {
          "blood_type": {
            "$ref": "#/components/schemas/BloodType"
          },
          "status": {
            "$ref": "#/components/schemas/StockStatus"
          },
          "last_updated": {
            "type": "string",
            "format": "date-time",
            "title": "Last Updated"
          }
        },
        "type": "object",
        "required": [
          "blood_type",
          "status",
          "last_updated"
        ],
        "title": "BloodStockDTO"
      },
      "BloodType": {
        "type": "string",
        "enum": [
          "A+",
          "A-",
          "B+",
          "B-",
          "AB+",
          "AB-",
          "O+",
          "O-"
        ],
        "title": "BloodType"
      },
      "DonorCreate": {
        "properties": {
          "full_name": {
            "type": "string",
            "title": "Full Name"
          },
          "email": {
            "type": "string",
            "format": "email",
            "title": "Email"
          },
          "blood_type": {
            "$ref": "#/components/schemas/BloodType"
          }
        },
        "type": "object",
        "required": [
          "full_name",
          "email",
          "blood_type"
        ],
        "title": "DonorCreate"
      },
      "DonorRead": {
        "properties": {
          "id": {
            "type": "integer",
            "title": "Id"
          },
          "full_name": {
            "type": "string",
            "title": "Full Name"
          },
          "email": {
            "type": "string",
            "format": "email",
            "title": "Email"
          },
          "blood_type": {
            "$ref": "#/components/schemas/BloodType"
          }
        },
        "type": "object",
        "required": [
          "id",
          "full_name",
          "email",
          "blood_type"
        ],
        "title": "DonorRead"
      },
      "HTTPValidationError": {
        "properties": {
          "detail": {
            "items": {
              "$ref": "#/components/schemas/ValidationError"
            },
            "type": "array",
            "title": "Detail"
          }
        },
        "type": "object",
        "title": "HTTPValidationError"
      },
      "NotificationLogDTO": {
        "properties": {
          "id": {
            "type": "string",
            "title": "Id"
          },
          "recipient_email": {
            "type": "string",
            "title": "Recipient Email"
          },
          "blood_type": {
            "$ref": "#/components/schemas/BloodType"
          },
          "status_at_time": {
            "$ref": "#/components/schemas/StockStatus"
          },
          "sent_at": {
            "type": "string",
            "format": "date-time",
            "title": "Sent At"
          }
        },
        "type": "object",
        "required": [
          "id",
          "recipient_email",
          "blood_type",
          "status_at_time",
          "sent_at"
        ],
        "title": "NotificationLogDTO"
      },
      "StockStatus": {
        "type": "string",
        "enum": [
          "Critical",
          "Alert",
          "Low",
          "Stable"
        ],
        "title": "StockStatus"
      },
      "ValidationError": {
        "properties": {
          "loc": {
            "items": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "integer"
                }
              ]
            },
            "type": "array",
            "title": "Location"
          },
          "msg": {
            "type": "string",
            "title": "Message"
          },
          "type": {
            "type": "string",
            "title": "Error Type"
          },
          "input": {
            "title": "Input"
          },
          "ctx": {
            "type": "object",
            "title": "Context"
          }
        },
        "type": "object",
        "required": [
          "loc",
          "msg",
          "type"
        ],
        "title": "ValidationError"
      }
    }
  }
}