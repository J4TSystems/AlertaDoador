      "post": {
        "tags": [
          "Notifications"
        ],
        "summary": "Trigger Notifications",
        "operationId": "trigger_notifications_notifications_send_alerts_post",
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {}
              }
            }
          }
        }
      }
    },
    "/notifications/history": {
      "get": {
        "tags": [
          "Notifications"
        ],
        "summary": "Get History",
        "operationId": "get_history_notifications_history_get",
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "items": {
