          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "items": {
                    "$ref": "#/components/schemas/DonorRead"
                  },
                  "type": "array",
                  "title": "Response Get Donors Donors  Get"
                }
              }
            }
          }
        }
      },
      "post": {
        "tags": [
          "donors"
        ],
        "summary": "Create Donor",
        "operationId": "create_donor_donors__post",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/DonorCreate"
              }
            }
          },
          "required": true
        },
        "responses": {
          "201": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DonorRead"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/donors/{donor_id}": {
      "get": {
        "tags": [
          "donors"
        ],
        "summary": "Get Donor",
        "operationId": "get_donor_donors__donor_id__get",
        "parameters": [
          {
            "name": "donor_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer",
              "title": "Donor Id"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DonorRead"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
