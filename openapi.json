        ],
        "summary": "Delete Donor",
        "operationId": "delete_donor_donors__donor_id__delete",
        "parameters": [
          {
            "name": "donor_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer",
              "title": "Donor Id"
            }
          }
        ],
        "responses": {
          "204": {
            "description": "Successful Response"
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
